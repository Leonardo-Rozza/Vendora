generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  CANCELLED
}

enum FulfillmentStatus {
  REQUESTED
  CONFIRMED
  PREPARING
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY
  DELIVERED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
}

enum WebhookDeliveryStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum UserRole {
  CUSTOMER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  firstName    String?
  lastName     String?
  role         UserRole @default(CUSTOMER)
  passwordHash String?
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String?
  status      ProductStatus    @default(DRAFT)
  variants    ProductVariant[]
  images      ProductImage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductVariant {
  id            String         @id @default(cuid())
  productId     String
  sku           String         @unique
  name          String
  priceAmount   Decimal        @db.Decimal(10, 2)
  currencyCode  String         @db.Char(3)
  inventoryItem InventoryItem?
  orderItems    OrderItem[]
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([productId])
}

model InventoryItem {
  id                String         @id @default(cuid())
  variantId         String         @unique
  availableQuantity Int            @default(0)
  reservedQuantity  Int            @default(0)
  variant           ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  assetUrl  String
  assetKey  String?
  altText   String?
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, sortOrder])
}

model Order {
  id                    String      @id @default(cuid())
  userId                String?
  status                OrderStatus @default(DRAFT)
  fulfillmentStatus     FulfillmentStatus @default(REQUESTED)
  currencyCode          String      @db.Char(3)
  subtotalAmount        Decimal     @db.Decimal(10, 2)
  totalAmount           Decimal     @db.Decimal(10, 2)
  contactFullName       String
  contactEmail          String
  contactPhone          String
  shippingRecipientName String
  shippingPhone         String
  shippingStreetLine1   String
  shippingStreetLine2   String?
  shippingLocality      String
  shippingProvince      String
  shippingPostalCode    String
  shippingDeliveryNotes String?
  fulfillmentNotes      String?
  deliveryReference     String?
  paidAt                DateTime?
  isLocked              Boolean     @default(false)
  user                  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  payments              Payment[]
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([fulfillmentStatus])
}

model OrderItem {
  id              String         @id @default(cuid())
  orderId         String
  variantId       String
  productName     String
  variantName     String
  sku             String
  unitPriceAmount Decimal        @db.Decimal(10, 2)
  quantity        Int
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([orderId])
  @@index([variantId])
}

model Payment {
  id                   String                   @id @default(cuid())
  orderId              String
  provider             String
  providerPaymentId    String?                  @unique
  providerPreferenceId String?                  @unique
  status               PaymentStatus            @default(PENDING)
  rawPayload           Json?
  confirmedAt          DateTime?
  order                Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  webhookDeliveries    PaymentWebhookDelivery[]
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@index([orderId])
  @@index([provider, status])
}

model PaymentWebhookDelivery {
  id              String                @id @default(cuid())
  provider        String
  providerEventId String
  topic           String?
  payload         Json
  status          WebhookDeliveryStatus @default(RECEIVED)
  paymentId       String?
  processedAt     DateTime?
  payment         Payment?              @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([provider, providerEventId])
  @@index([paymentId])
}
