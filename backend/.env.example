# ─── Vendora backend environment ───────────────────────────────────────────
# Copy to .env (or .env.local) and fill in real values. Variables are validated
# at boot by src/platform/config/env.validation.ts.

# Runtime
NODE_ENV=development
PORT=3000
APP_NAME=vendora-backend

# Database (REQUIRED in production)
DATABASE_URL=postgresql://user:password@localhost:5432/vendora

# Frontend allowlist — comma-separated origins. Used for CORS and admin CSRF
# origin checks. REQUIRED in production (the old *.vercel.app wildcard is gone).
FRONTEND_APP_URL=http://localhost:3001

# Admin session (cookie signed with HMAC).
# ADMIN_SESSION_SECRET is REQUIRED in production: must be a strong, non-default
# value of at least 32 characters (e.g. `openssl rand -base64 48`).
ADMIN_SESSION_SECRET=
ADMIN_SESSION_COOKIE_NAME=vendora_admin_session
# lax | none | strict — defaults to 'none' in production (cross-site frontend),
# 'lax' otherwise. With 'none', CSRF is defended via the Origin allowlist.
ADMIN_SESSION_COOKIE_SAME_SITE=
ADMIN_SESSION_TTL_HOURS=12

# Bootstrap admin (optional; both required together). Seeds the first admin.
ADMIN_INITIAL_EMAIL=
ADMIN_INITIAL_PASSWORD=

# Mercado Pago (optional; both required together to enable checkout/webhooks).
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Cloudinary (optional; all three required together to enable image signing).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Notification email (optional; API key + from required together).
NOTIFICATION_EMAIL_API_BASE_URL=https://api.resend.com
NOTIFICATION_EMAIL_API_KEY=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_FROM_NAME=
NOTIFICATION_EMAIL_REPLY_TO=

# Orders — minutes a PENDING_PAYMENT order may hold its stock reservation
# before the abandoned-checkout job cancels it and releases the stock.
ORDER_PENDING_TTL_MINUTES=60
